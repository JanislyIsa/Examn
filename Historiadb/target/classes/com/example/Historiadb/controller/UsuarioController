package com.example.Historiadb.controller;

import com.example.Historiadb.model.Usuario;
import com.example.Historiadb.service.MedicoService;
import com.example.Historiadb.service.UsuarioService;
import jakarta.validation.Valid;
import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.validation.BindingResult;
import org.springframework.web.bind.annotation.*;

@Controller
@RequestMapping("/usuario")
public class UsuarioController {

    private static final String VIEW = "usuario/listusuarios";
    private static final String REDIRECT = "redirect:/usuario";

    private final UsuarioService usuarioService;
    private final MedicoService medicoService;

    public UsuarioController(UsuarioService usuarioService, MedicoService medicoService) {
        this.usuarioService = usuarioService;
        this.medicoService = medicoService;
    }

    @GetMapping
    public String listar(Model model) {
        cargarFormulario(model);
        return VIEW;
    }

    @PostMapping("/save")
    public String save(@Valid @ModelAttribute("usuario") Usuario usuario, BindingResult result, Model model) {
        if (result.hasErrors()) {
            cargarDatos(model);
            return VIEW;
        }
        try {
            if (usuario.getId() == null) {
                usuarioService.create(usuario);
            } else {
                usuarioService.update(usuario);
            }
        } catch (Exception e) {
            model.addAttribute("error", "Error al guardar usuario: " + e.getMessage());
            cargarDatos(model);
            return VIEW;
        }
        return REDIRECT;
    }

    @GetMapping("/eliminar/{id}")
    public String eliminar(@PathVariable Long id) {
        usuarioService.delete(id);
        return REDIRECT;
    }

    @GetMapping("/editar/{id}")
    public String editar(@PathVariable Long id, Model model) {
        Usuario usuario = usuarioService.read(id).orElse(null);
        if (usuario == null) return REDIRECT;

        cargarDatos(model);
        model.addAttribute("usuario", usuario);
        return VIEW;
    }

    private void cargarFormulario(Model model) {
        cargarDatos(model);
        model.addAttribute("usuario", new Usuario());
    }

    private void cargarDatos(Model model) {
        model.addAttribute("usuarios", usuarioService.readAll());
        model.addAttribute("medicos", medicoService.readAll());
    }
}